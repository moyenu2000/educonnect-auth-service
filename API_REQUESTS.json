{
  "base_url": "http://34.68.47.215:8081/api/auth",
  "endpoints": {
    "authentication": {
      "register": {
        "method": "POST",
        "url": "{{base_url}}/auth/register",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "username": "testuser",
          "email": "test@example.com",
          "password": "password123",
          "fullName": "Test User",
          "role": "STUDENT"
        },
        "description": "Register a new user account. Available roles: STUDENT, QUESTION_SETTER, ADMIN"
      },
      "login": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "usernameOrEmail": "testuser",
          "password": "password123"
        },
        "description": "Login with username/email and password"
      },
      "verify_2fa": {
        "method": "POST",
        "url": "{{base_url}}/auth/verify-2fa",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "tempToken": "temp_token_from_login",
          "code": "123456"
        },
        "description": "Verify 2FA code after login if 2FA is enabled"
      },
      "refresh_token": {
        "method": "POST",
        "url": "{{base_url}}/auth/refresh-token",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "refreshToken": "refresh_token_here"
        },
        "description": "Refresh access token using refresh token"
      },
      "logout": {
        "method": "POST",
        "url": "{{base_url}}/auth/logout",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "refreshToken": "refresh_token_here"
        },
        "description": "Logout user and invalidate tokens"
      }
    },
    "email_verification": {
      "verify_email": {
        "method": "GET",
        "url": "{{base_url}}/auth/verify-email?token=verification_token_here",
        "headers": {},
        "body": null,
        "description": "Verify email address using token from email"
      },
      "resend_verification": {
        "method": "POST",
        "url": "{{base_url}}/auth/resend-verification",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "test@example.com"
        },
        "description": "Resend email verification link"
      }
    },
    "password_management": {
      "forgot_password": {
        "method": "POST",
        "url": "{{base_url}}/auth/forgot-password",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "test@example.com"
        },
        "description": "Request password reset email"
      },
      "reset_password": {
        "method": "POST",
        "url": "{{base_url}}/auth/reset-password",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "token": "reset_token_here",
          "newPassword": "newpassword123",
          "confirmPassword": "newpassword123"
        },
        "description": "Reset password using token from email"
      },
      "change_password": {
        "method": "POST",
        "url": "{{base_url}}/auth/change-password",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "currentPassword": "oldpassword123",
          "newPassword": "newpassword123",
          "confirmPassword": "newpassword123"
        },
        "description": "Change password for authenticated user"
      }
    },
    "user_profile": {
      "get_current_user": {
        "method": "GET",
        "url": "{{base_url}}/auth/me",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "body": null,
        "description": "Get current authenticated user profile"
      },
      "update_profile": {
        "method": "PUT",
        "url": "{{base_url}}/auth/profile",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "fullName": "Updated Name",
          "bio": "Updated bio",
          "avatarUrl": "https://example.com/new-avatar.jpg"
        },
        "description": "Update user profile information"
      }
    },
    "two_factor_authentication": {
      "enable_2fa": {
        "method": "POST",
        "url": "{{base_url}}/auth/2fa/enable",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "body": null,
        "description": "Enable two-factor authentication and get QR code"
      },
      "confirm_2fa": {
        "method": "POST",
        "url": "{{base_url}}/auth/2fa/confirm",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "code": "123456"
        },
        "description": "Confirm 2FA setup with verification code"
      },
      "disable_2fa": {
        "method": "POST",
        "url": "{{base_url}}/auth/2fa/disable",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "password": "password123"
        },
        "description": "Disable two-factor authentication"
      }
    },
    "oauth2": {
      "google_oauth2_login": {
        "method": "GET",
        "url": "{{base_url}}/oauth2/authorize/google?redirect_uri={{redirect_uri}}",
        "headers": {},
        "body": null,
        "description": "Initiate Google OAuth2 login flow"
      },
      "oauth2_callback": {
        "method": "GET",
        "url": "{{base_url}}/oauth2/callback/google?code=authorization_code&state=state_value",
        "headers": {},
        "body": null,
        "description": "OAuth2 callback endpoint (handled automatically by browser)"
      }
    },
    "admin_endpoints": {
      "get_all_users": {
        "method": "GET",
        "url": "{{base_url}}/auth/admin/users?page=0&size=10",
        "headers": {
          "Authorization": "Bearer {{access_token}}"
        },
        "body": null,
        "description": "Get all users (Admin only)"
      },
      "update_user_role": {
        "method": "PUT",
        "url": "{{base_url}}/auth/admin/users/1/role",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "role": "QUESTION_SETTER"
        },
        "description": "Update user role (Admin only)"
      },
      "update_user_status": {
        "method": "PUT",
        "url": "{{base_url}}/auth/admin/users/1/status",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {{access_token}}"
        },
        "body": {
          "enabled": false
        },
        "description": "Enable/disable user account (Admin only)"
      }
    }
  },
  "variables": {
    "base_url": "http://34.68.47.215:8081/api/auth",
    "access_token": "your_jwt_access_token_here",
    "refresh_token": "your_jwt_refresh_token_here",
    "temp_token": "your_temp_token_for_2fa_here",
    "redirect_uri": "http://localhost:3000/oauth2/redirect"
  },
  "usage_notes": {
    "authentication": "Replace {{access_token}} with actual JWT token after login",
    "tokens": "Tokens are returned in login/2fa verification responses",
    "admin_endpoints": "Require ADMIN role user authentication",
    "oauth2": "Google OAuth2 requires proper client configuration"
  }
} 