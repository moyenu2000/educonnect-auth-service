    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-extract tokens from responses",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    const responseJson = pm.response.json();",
          "    ",
          "    // Extract access token",
          "    if (responseJson.accessToken) {",
          "        pm.environment.set('access_token', responseJson.accessToken);",
          "    }",
          "    ",
          "    // Extract refresh token",
          "    if (responseJson.refreshToken) {",
          "        pm.environment.set('refresh_token', responseJson.refreshToken);",
          "    }",
          "    ",
          "    // Extract temp token for 2FA",
          "    if (responseJson.tempToken) {",
          "        pm.environment.set('temp_token', responseJson.tempToken);",
          "    }",
          "}"
        ]
      }
    }
